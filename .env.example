# =============================================================================
# SentryLive Demo -- Environment Variables
# You normally do NOT need to edit this file: run_demo.py writes a real .env
# for you from the --google-api-key / --pageindex-api-key arguments you pass
# on the command line. This file is just a reference for what's configurable.
# =============================================================================

# Required -- get yours at https://console.cloud.google.com/agent-platform/studio/settings/api-keys
GOOGLE_API_KEY=your-google-api-key-here

# Required -- must be the key for the PageIndex account that indexed the guidelines
# bundled with this package (data/guidelines/doc_ids.json) -- a different account's
# key will fail. Use the key provided alongside this package, not a fresh one you
# create yourself, unless you first delete doc_ids.json to re-index under your own
# account (see README.md).
PAGEINDEX_API_KEY=your-pageindex-api-key-here

# Models (all optional -- sensible defaults are used if unset)
CONCEPT_EXTRACTION_MODEL=gemini-2.5-flash
ANSWER_GENERATION_MODEL=gemini-2.5-flash

# Guideline retrieval specifically requires a Gemini 2.5 model -- the MCP tool
# integration used for retrieval does not support Gemini 3.x. Leave this as-is
# even if you change the other two models above.
RETRIEVAL_MODEL=gemini-2.5-flash

# Lower = more deterministic, consistent clinical answers. Range 0.0-2.0.
TEMPERATURE=0.1
